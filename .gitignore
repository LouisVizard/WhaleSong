# ==========================================
# Jupyter Notebooks & IPython
# ==========================================
# Autosave checkpoints created by Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# IPython configuration files
.ipython/
profile_default/
ipython_config.py

# Jupyter cache files
.jupyter_cache/
.pytest_cache/

# ==========================================
# Local Data & Large Files
# ==========================================
# Avoid committing raw datasets or heavy outputs
*.csv
*.json
*.xlsx
*.parquet
*.pickle
*.pkl
*.h5

# ==========================================
# Virtual Environments & Packages
# ==========================================
# Local Python environments
.venv/
venv/
env/
ENV/
bin/
lib/
develop-eggs/
dist/
eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/

# ==========================================
# Credentials & Secrets
# ==========================================
# Never commit credentials or local variables
.env
.secret
credentials.json

# ==========================================
# IDEs & Operating Systems
# ==========================================
# VS Code, PyCharm, and Mac metadata
.vscode/
.idea/
.DS_Store
Thumbs.db